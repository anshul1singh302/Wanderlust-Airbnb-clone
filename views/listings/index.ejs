<% layout("/layouts/boilerplate") %>

<style>
  #filters {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.5rem;
  }

  .filter {
    text-align: center;
    margin-top: 1rem;
    opacity: 0.7;
  }

  .filter:hover {
    opacity: 1;
    cursor: pointer;
  }

  .filter p {
    font-size: 0.8rem;
    margin: 0;
  }

  .tax-info {
    display: none;
    border: 1px solid black;
    border-radius: 1rem;
    padding: 0.3rem 0.6rem;
    margin-left: 0.5rem;
    font-size: 0.75rem;
  }

  .tax-toggle {
    margin-left: auto;
  }
</style>

<div id="filters">
  <div class="filter">
    <i class="fa-solid fa-fire"></i>
    <p>Trending</p>
  </div>

  <div class="filter">
    <i class="fa-solid fa-bed"></i>
    <p>Rooms</p>
  </div>

  <div class="filter">
    <i class="fa-solid fa-mountain-city"></i>
    <p>Iconic Cities</p>
  </div>

  <div class="filter">
    <i class="fa-solid fa-mountain"></i>
    <p>Mountains</p>
  </div>

  <div class="filter">
    <i class="fa-brands fa-fort-awesome"></i>
    <p>Castles</p>
  </div>

  <div class="filter">
    <i class="fa-solid fa-person-swimming"></i>
    <p>Amazing Pools</p>
  </div>

  <div class="filter">
    <i class="fa-solid fa-campground"></i>
    <p>Camping</p>
  </div>

  <div class="filter">
    <i class="fa-solid fa-cow"></i>
    <p>Farms</p>
  </div>

  <div class="filter">
    <i class="fa-solid fa-snowflake"></i>
    <p>Arctic</p>
  </div>

  <div class="filter">
    <i class="fa-solid fa-igloo"></i>
    <p>Dome</p>
  </div>

  <div class="filter">
    <i class="fa-solid fa-sailboat"></i>
    <p>Boats</p>
  </div>

  <div class="tax-toggle">
    <div class="form-check-reverse form-switch">
      <input 
        class="form-check-input" 
        type="checkbox" 
        id="taxSwitch"
      >
      <label class="form-check-label" for="taxSwitch">
        Display total after taxes
      </label>
    </div>
  </div>
</div>

<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
  <% for (let listing of allListings) { %>
    <div class="col">
      <a href="/listings/<%= listing._id %>" class="listing-link text-decoration-none">
        <div class="card listing-card h-100">
          <img 
            src="<%= listing.image.url %>" 
            class="card-img-top" 
            alt="listing_image"
            style="height: 20rem; object-fit: cover;"
          />

          <div class="card-body">
            <p class="card-text">
              <b><%= listing.title %></b><br>
              &#8377;<%= listing.price?.toLocaleString("en-IN") || "N/A" %>/night
              <span class="tax-info">+18% GST</span>
            </p>
          </div>
        </div>
      </a>
    </div>
  <% } %>
</div>

<script>
  const taxSwitch = document.getElementById("taxSwitch");

  taxSwitch.addEventListener("change", () => {
    const taxInfo = document.querySelectorAll(".tax-info");

    taxInfo.forEach(info => {
      info.style.display = taxSwitch.checked ? "inline" : "none";
    });
  });
</script>